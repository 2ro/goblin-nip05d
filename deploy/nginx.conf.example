# nginx reverse-proxy example for a bare-metal name authority + relay.
#
# Terminates TLS, sets X-Real-IP (security-critical), routes the NIP-05 and
# API paths to goblin-nip05d on loopback, and proxies the relay websocket.
#
# Assumes:
#   - goblin-nip05d listening on 127.0.0.1:8191 (NIP05_BIND)
#   - nostr-rs-relay listening on 127.0.0.1:8080
#   - certificates provisioned (e.g. by certbot) for your domain
#
# Replace names.example with your own GOBLIN_DOMAIN.

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 80;
    server_name names.example;
    # Redirect everything to HTTPS.
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    http2 on;
    server_name names.example;

    ssl_certificate     /etc/letsencrypt/live/names.example/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/names.example/privkey.pem;

    # NIP-05 resolution and the registration/avatar API → the name authority.
    location /.well-known/nostr.json {
        proxy_pass http://127.0.0.1:8191;
        proxy_set_header Host $host;
        # SECURITY-CRITICAL: the authority rate-limits per X-Real-IP. If this
        # header is unset or spoofable, every caller looks like one IP and the
        # limiter is defeated. $remote_addr is the real connecting peer.
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:8191;
        proxy_set_header Host $host;
        # SECURITY-CRITICAL — see above. Rate limiting depends on this.
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # The relay (websocket + NIP-11 info document) at the root.
    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;
    }
}

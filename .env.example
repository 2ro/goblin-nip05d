# goblin-nip05d configuration. Copy to `.env` (for docker compose) or to
# /etc/goblin-nip05d.env (for the systemd unit) and edit for your deployment.
# Every value shown is the built-in default, so an unset variable behaves
# exactly like the line below.

# --- Identity (the part you MUST change to run your own authority) ---

# Bare host your names live under — the `@domain` in `name@domain`.
GOBLIN_DOMAIN=goblin.st

# Public base URL clients actually reach. LOAD-BEARING: NIP-98 auth events are
# verified against `<GOBLIN_BASE_URL><path>`, so this MUST be https:// and its
# host MUST equal GOBLIN_DOMAIN (a port is allowed). A wrong value silently
# breaks every authenticated call. The service refuses to start if it and
# GOBLIN_DOMAIN disagree.
GOBLIN_BASE_URL=https://goblin.st

# Comma-separated relays advertised in /.well-known/nostr.json. If you run the
# bundled relay, point this at your own wss:// URL (e.g. wss://goblin.st).
GOBLIN_RELAYS=wss://nrelay.us-ea.st

# --- Listener / storage ---

# Address the service binds. Behind a proxy on bare metal use loopback; inside
# the container the entrypoint already sets 0.0.0.0:8191.
NIP05_BIND=127.0.0.1:8191

# SQLite database path.
NIP05_DB=/opt/goblin/nip05d/nip05.db

# Directory for processed avatar PNGs.
AVATAR_DIR=/opt/goblin/nip05d/avatars

# --- Policy tunables ---

# Seconds a key must wait to claim a new name after releasing one (anti-churn).
GOBLIN_NAME_CHANGE_COOLDOWN_SECS=600

# Avatar changes allowed per name per rolling 24h.
GOBLIN_AVATARS_PER_DAY=5

# Max age (seconds) of an accepted NIP-98 auth event.
GOBLIN_AUTH_MAX_AGE_SECS=60

# Allowed name length, in characters.
GOBLIN_NAME_MIN=3
GOBLIN_NAME_MAX=30

# --- Rate-limit ceilings (per X-Real-IP) ---

# Read endpoints: max requests per window / window length in seconds.
GOBLIN_READ_RATE_MAX=120
GOBLIN_READ_RATE_WINDOW_SECS=60

# Write endpoints (register/transfer/release/avatar).
GOBLIN_WRITE_RATE_MAX=10
GOBLIN_WRITE_RATE_WINDOW_SECS=3600

# --- Optional ---

# Path to a file of additional reserved names (one per line, # comments).
# Extends the built-in reserved list. Leave unset to use only the built-ins.
# GOBLIN_RESERVED_FILE=/etc/goblin-nip05d.reserved
